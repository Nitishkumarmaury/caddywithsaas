# =========================
# 1. MAIN SAAS WILDCARD DOMAIN
# =========================
*.plantgen.live {

  tls {
    dns namedotcom {
      user nitishkumar200485@gmail.com
      token b3f1dec632437b8857dc0a8825dcdf6d639bbf61
      server https://api.name.com
    }
  }

  reverse_proxy localhost:3000 {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
  }
}

# =========================
# 2. CUSTOM CLIENT DOMAINS (AUTO SSL)
# =========================
:443 {

  tls {
    on_demand
  }

  reverse_proxy localhost:3000 {
    header_up Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
  }
}

# =========================
# 3. HTTP → HTTPS REDIRECT
# =========================
:80 {
  redir https://{host}{uri} permanent
}

