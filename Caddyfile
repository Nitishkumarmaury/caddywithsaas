{
  email admin@MYDOMAIN.com
  on_demand_tls {
    ask http://localhost:3000/caddy/ask?domain={host}&token={env.ASK_SECRET}
  }
}

# Wildcard for subdomains (requires DNS challenge and Name.com DNS module).
# Set NAMEDOTCOM_USER, NAMEDOTCOM_TOKEN, NAMEDOTCOM_SERVER in the Caddy environment.
# Use https://api.name.com for production or https://api.dev.name.com for testing.
*.MYDOMAIN.com {
  tls {
    dns namedotcom {
      user {$NAMEDOTCOM_USER}
      token {$NAMEDOTCOM_TOKEN}
      server {$NAMEDOTCOM_SERVER}
    }
  }
  reverse_proxy localhost:3000 {
    header_up Host {host}
  }
}

# Custom domains (on-demand TLS, verified via /caddy/ask).
:443 {
  tls {
    on_demand
  }
  reverse_proxy localhost:3000 {
    header_up Host {host}
  }
}

# Optional HTTP redirect for custom domains.
:80 {
  redir https://{host}{uri} permanent
}
